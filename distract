    <!-- --- JAVASCRIPT --- -->
    <script>
        // Init Icônes Lucide
        lucide.createIcons();

        // Gestion Heure Dynamique
        function updateTime() {
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
            document.getElementById('datetime').innerText = now.toLocaleString('fr-FR', options);
        }
        setInterval(updateTime, 1000);
        updateTime();

        // Système de Navigation par Onglets
        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(btn => btn.classList.remove('active', 'text-slate-800'));
            
            document.getElementById(tabId).classList.add('active');
            
            // Textual Page Title update
            const titles = {
                ventes: 'Pipeline Commercial (DH)', 
                livraison: 'Logistique & Livraison Maroc', 
                contacts: 'Réseau de Partenaires Alimentaires', 
                analyse: 'Intelligence Performance Soufiane'
            };
            document.getElementById('page-title').innerText = titles[tabId];
            
            // Styling current link
            event.currentTarget.classList.add('active');
        }

        // Système de Panneau Latéral
        function openPanel(title, amount, company) {
            document.getElementById('panel-title').innerText = title;
            document.getElementById('panel-amount').innerText = amount + ' DH';
            document.getElementById('panel-company').innerText = company;
            document.getElementById('side-panel-overlay').classList.remove('hidden');
            document.getElementById('side-panel').classList.add('open');
        }

        function closePanel() {
            document.getElementById('side-panel-overlay').classList.add('hidden');
            document.getElementById('side-panel').classList.remove('open');
        }
    </script>
